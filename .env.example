# Copy to .env and fill in. Bun loads this automatically.
PORT=3000

# Cron expression for rate polling. Default: every 15 minutes.
# Note: Bun.cron runs in UTC. Factor in your timezone for hour-specific schedules.
POLL_CRON=*/15 * * * *

# SQLite file location (relative to repo root).
DB_PATH=./data/dashboard.db

# Base path the frontend is served from. Leave unset to serve at the domain root.
# Set to "/signal/" (trailing slash) if Nginx proxies a sub-path to this app.
# Read at build time by Vite — you must re-run `bun run build` after changing it.
# VITE_BASE_PATH=/signal/
